# ─────────────────────────────────────────────────────────────
# AniMatch · variables de entorno para docker-compose
# Copia este archivo a `.env` en la VM y rellena los valores reales.
# El `.env` NUNCA se sube a git (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Gemini (Google AI Studio)
GEMINI_API_KEY=tu-api-key-de-gemini

# Login con Google (OAuth, console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Contraseña del usuario "animatch" en el Postgres compartido de la VM
ANIMATCH_DB_PASSWORD=la-password-del-usuario-animatch
